# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change_this_to_a_very_long_random_secret_key_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=aeroquant
POSTGRES_PASSWORD=aeroquant_secret
POSTGRES_DB=aeroquant_db
DATABASE_URL=postgresql://aeroquant:aeroquant_secret@localhost:5432/aeroquant_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ─── AWS (optional — for S3 model storage) ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=aeroquant-models

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api

# ─── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
# ─── ML Feature Flags ─────────────────────────────────────────────────────────
# Set to 1 to enable (requires shap / prophet installed)
SHAP_ENABLED=1
PROPHET_ENABLED=1